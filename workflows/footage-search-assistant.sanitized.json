                      "type":  "n8n-nodes-base.set",
                      "typeVersion":  3.4,
                      "position":  [
                                       976,
                                       0
                                   ],
                      "id":  "0ca82b2b-942a-4e32-8a77-f4e4e2923b46",
                      "name":  "Parse Search Results"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const input = $input.first().json;\nconst results = input.search_results || {};\n\nconst matches = Array.isArray(results.matches)\n  ? results.matches\n  : [];\n\nfunction escapeHtml(value = \u0027\u0027) {\n  return String(value).replace(/[\u0026\u003c\u003e\"\u0027]/g, character =\u003e ({\n    \u0027\u0026\u0027: \u0027\u0026amp;\u0027,\n    \u0027\u003c\u0027: \u0027\u0026lt;\u0027,\n    \u0027\u003e\u0027: \u0027\u0026gt;\u0027,\n    \u0027\"\u0027: \u0027\u0026quot;\u0027,\n    \"\u0027\": \u0027\u0026#039;\u0027,\n  })[character]);\n}\n\nlet resultHtml;\n\nif (results.no_match || matches.length === 0) {\n  resultHtml = `\n    \u003cdiv style=\"max-width:800px;margin:0 auto;font-family:Arial,sans-serif;\"\u003e\n      \u003ch2\u003eNo Relevant Footage Found\u003c/h2\u003e\n      \u003cp\u003e\n        No cataloged footage matched\n        \u003cstrong\u003e${escapeHtml(results.search_query)}\u003c/strong\u003e.\n      \u003c/p\u003e\n    \u003c/div\u003e\n  `;\n} else {\n  const matchCards = matches.map(match =\u003e {\n    const category = escapeHtml(match.category).replace(/_/g, \u0027 \u0027);\n\n    const warning = match.warning\n      ? `\n        \u003cp style=\"color:#b45309;\"\u003e\n          \u003cstrong\u003eWarning:\u003c/strong\u003e\n          ${escapeHtml(match.warning)}\n        \u003c/p\u003e\n      `\n      : \u0027\u0027;\n\n    return `\n      \u003cdiv style=\"\n        border:1px solid #d1d5db;\n        border-radius:10px;\n        padding:18px;\n        margin:16px 0;\n        background:#ffffff;\n      \"\u003e\n        \u003ch3 style=\"margin-top:0;\"\u003e\n          #${escapeHtml(match.rank)} —\n          ${escapeHtml(match.original_clip_name)}\n        \u003c/h3\u003e\n\n        \u003cp\u003e\n          \u003cstrong\u003eProxy:\u003c/strong\u003e\n          ${escapeHtml(match.proxy_clip_name)}\n        \u003c/p\u003e\n\n        \u003cp\u003e\n          \u003cstrong\u003eCategory:\u003c/strong\u003e\n          ${category}\n        \u003c/p\u003e\n\n        \u003cp\u003e\n          \u003cstrong\u003eRelevance:\u003c/strong\u003e\n          ${escapeHtml(match.relevance_score)}%\n        \u003c/p\u003e\n\n        \u003cp\u003e\n          \u003cstrong\u003eTimecode:\u003c/strong\u003e\n          ${escapeHtml(match.matching_timecode || \u0027Not available\u0027)}\n        \u003c/p\u003e\n\n        \u003cp\u003e\n          \u003cstrong\u003eWhy it matched:\u003c/strong\u003e\n          ${escapeHtml(match.match_reason)}\n        \u003c/p\u003e\n\n        ${warning}\n      \u003c/div\u003e\n    `;\n  }).join(\u0027\u0027);\n\n  resultHtml = `\n    \u003cdiv style=\"max-width:800px;margin:0 auto;font-family:Arial,sans-serif;\"\u003e\n      \u003ch2\u003eFootage Search Results\u003c/h2\u003e\n\n      \u003cp\u003e\n        \u003cstrong\u003eSearch:\u003c/strong\u003e\n        ${escapeHtml(results.search_query)}\n      \u003c/p\u003e\n\n      \u003cp\u003e\n        ${matches.length}\n        matching clip${matches.length === 1 ? \u0027\u0027 : \u0027s\u0027} found.\n      \u003c/p\u003e\n\n      ${matchCards}\n    \u003c/div\u003e\n  `;\n}\n\nreturn [\n  {\n    json: {\n      ...input,\n      result_html: resultHtml,\n    },\n  },\n];"
                                     },
